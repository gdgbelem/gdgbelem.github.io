{
  "name": "gdg-belem-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "yarn studio:types",
    "dev": "next dev",
    "studio": "nextjs-studio",
    "studio:types": "nextjs-studio --generate-types",
    "prebuild": "yarn studio:types && node .claude/skills/impeccable/scripts/live-inject.mjs --remove > /dev/null 2>&1 || true",
    "build": "next build",
    "postbuild": "yarn check:no-live && yarn sitemap",
    "check:no-live": "! grep -rl 'localhost:8400' out 2>/dev/null || (echo 'ERROR: impeccable live tag leaked into build output' && exit 1)",
    "sitemap": "next-sitemap --config next-sitemap.config.cjs",
    "serve": "npx --yes serve out",
    "lint": "eslint",
    "ts-check": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@mdx-js/mdx": "^3.1.1",
    "@tabler/icons-react": "^3.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-mdx-remote": "^6.0.0",
    "nextjs-studio": "^1.0.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "next-sitemap": "^4.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
